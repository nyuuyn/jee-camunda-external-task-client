<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions
    xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
    xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
    xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
    xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
    xmlns:camunda="http://camunda.org/schema/1.0/bpmn"
    id="Definitions_1"
    targetNamespace="http://bpmn.io/schema/bpmn"
    exporter="Camunda Modeler"
    exporterVersion="5.0.0">

  <bpmn:process id="add-note-process" name="Add Note Process" isExecutable="true"
               camunda:historyTimeToLive="P1D">

    <bpmn:startEvent id="StartEvent_1" name="Start">
      <bpmn:outgoing>Flow_start_to_task</bpmn:outgoing>
    </bpmn:startEvent>

    <!--
      External Service Task – handled by AddNoteHandler.
      Expected input variables:  title (String), content (String)
      Output variable:           noteId (Long)
    -->
    <bpmn:serviceTask id="Task_AddNote"
                      name="Add Note"
                      camunda:type="external"
                      camunda:topic="add-note">
      <bpmn:incoming>Flow_start_to_task</bpmn:incoming>
      <bpmn:outgoing>Flow_task_to_end</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:endEvent id="EndEvent_1" name="End">
      <bpmn:incoming>Flow_task_to_end</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:sequenceFlow id="Flow_start_to_task"
                       sourceRef="StartEvent_1"
                       targetRef="Task_AddNote"/>

    <bpmn:sequenceFlow id="Flow_task_to_end"
                       sourceRef="Task_AddNote"
                       targetRef="EndEvent_1"/>

  </bpmn:process>

  <bpmndi:BPMNDiagram id="BPMNDiagram_1">
    <bpmndi:BPMNPlane id="BPMNPlane_1" bpmnElement="add-note-process">

      <bpmndi:BPMNShape id="StartEvent_1_di" bpmnElement="StartEvent_1">
        <dc:Bounds x="152" y="82" width="36" height="36"/>
        <bpmndi:BPMNLabel>
          <dc:Bounds x="158" y="125" width="24" height="14"/>
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="Task_AddNote_di" bpmnElement="Task_AddNote">
        <dc:Bounds x="260" y="60" width="100" height="80"/>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="EndEvent_1_di" bpmnElement="EndEvent_1">
        <dc:Bounds x="432" y="82" width="36" height="36"/>
        <bpmndi:BPMNLabel>
          <dc:Bounds x="440" y="125" width="20" height="14"/>
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNEdge id="Flow_start_to_task_di" bpmnElement="Flow_start_to_task">
        <di:waypoint x="188" y="100"/>
        <di:waypoint x="260" y="100"/>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_task_to_end_di" bpmnElement="Flow_task_to_end">
        <di:waypoint x="360" y="100"/>
        <di:waypoint x="432" y="100"/>
      </bpmndi:BPMNEdge>

    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>

</bpmn:definitions>